<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>千葉工業大学 出席管理</title>

<style>
    body{
        font-family: sans-serif;
        background:#f4f4f4;
        margin:0;
        padding:20px;
    }

    h1{
        text-align:center;
    }

    #clock{
        text-align:center;
        font-size:24px;
        margin-bottom:20px;
        font-weight:bold;
    }

    .card{
        background:white;
        border-radius:12px;
        padding:16px;
        margin-bottom:16px;
        box-shadow:0 2px 8px rgba(0,0,0,0.1);
    }

    .subject{
        font-size:20px;
        font-weight:bold;
        margin-bottom:8px;
    }

    .time{
        color:#666;
        margin-bottom:8px;
    }

    .room{
        margin-bottom:12px;
    }

    .status{
        font-weight:bold;
        margin-bottom:12px;
    }

    .available{
        color:green;
    }

    .waiting{
        color:orange;
    }

    .ended{
        color:red;
    }

    button{
        width:100%;
        padding:12px;
        border:none;
        border-radius:8px;
        font-size:16px;
        cursor:pointer;
    }

    .active-btn{
        background:#007bff;
        color:white;
    }

    .disabled-btn{
        background:#ccc;
        color:#666;
        cursor:not-allowed;
    }
</style>
</head>
<body>

<h1>出席システム</h1>

<div id="clock"></div>

<div id="schedule"></div>

<script>
const baseUrl =
"https://attendance.is.it-chiba.ac.jp/attendance/class_room/";

const timetable = {
    1: [
        {
            subject:"情報メディア基礎",
            room:"5103",
            start:"10:00",
            end:"12:00"
        },
        {
            subject:"NWプログラミング基礎演習",
            room:"3212",
            start:"13:00",
            end:"17:00"
        }
    ],

    2: [
        {
            subject:"TCP/IP概論",
            room:"8102",
            start:"09:00",
            end:"10:00"
        },
        {
            subject:"英語理解 3f",
            room:"5205",
            start:"10:00",
            end:"12:00"
        },
        {
            subject:"微分方程式",
            room:"8206",
            start:"13:00",
            end:"15:00"
        }
    ],

    3: [
        {
            subject:"データ構造とアルゴリズム",
            room:"3212",
            start:"10:00",
            end:"12:00"
        },
        {
            subject:"確率統計",
            room:"8109",
            start:"13:00",
            end:"15:00"
        },
        {
            subject:"数理モデリング",
            room:"8201",
            start:"15:00",
            end:"17:00"
        }
    ],

    4: [
        {
            subject:"情報数学1",
            room:"7202",
            start:"10:00",
            end:"12:00"
        }
    ],

    5: [
        {
            subject:"キャリアデザイン",
            room:"11号館2階演習室2",
            start:"10:00",
            end:"12:00"
        },
        {
            subject:"英語表現",
            room:"5304",
            start:"13:00",
            end:"15:00"
        },
        {
            subject:"倫理学",
            room:"5102",
            start:"15:00",
            end:"17:00"
        }
    ]
};

function updateClock(){
    const now = new Date();

    document.getElementById("clock").innerText =
        "現在時刻: " +
        now.toLocaleTimeString("ja-JP");
}

function timeToMinutes(timeStr){
    const [h,m] = timeStr.split(":").map(Number);
    return h * 60 + m;
}

function renderSchedule(){
    const now = new Date();

    const day = now.getDay();

    const currentMinutes =
        now.getHours() * 60 + now.getMinutes();

    const container =
        document.getElementById("schedule");

    container.innerHTML = "";

    const todayClasses = timetable[day];

    if(!todayClasses){
        container.innerHTML =
            "<div class='card'>今日は授業なし</div>";
        return;
    }

    todayClasses.forEach(cls => {

        const start =
            timeToMinutes(cls.start);

        const end =
            timeToMinutes(cls.end);

        const openTime =
            start - 30;

        let status = "";
        let statusClass = "";
        let buttonDisabled = true;

        if(currentMinutes >= openTime &&
           currentMinutes <= end){

            status = "✅ 出席可能";
            statusClass = "available";
            buttonDisabled = false;

        }else if(currentMinutes < openTime){

            status = "⏳ 受付前";
            statusClass = "waiting";

        }else{

            status = "❌ 授業終了";
            statusClass = "ended";
        }

        const card =
            document.createElement("div");

        card.className = "card";

        const url =
            baseUrl + encodeURIComponent(cls.room);

        card.innerHTML = `
            <div class="subject">
                ${cls.subject}
            </div>

            <div class="time">
                ${cls.start} - ${cls.end}
            </div>

            <div class="room">
                教室: ${cls.room}
            </div>

            <div class="status ${statusClass}">
                ${status}
            </div>

            <button
                class="${
                    buttonDisabled
                    ? "disabled-btn"
                    : "active-btn"
                }"
                ${
                    buttonDisabled
                    ? "disabled"
                    : `onclick="window.open('${url}','_blank')"`
                }
            >
                出席する
            </button>
        `;

        container.appendChild(card);
    });
}

function update(){
    updateClock();
    renderSchedule();
}

update();

setInterval(update,1000);
</script>

</body>
</html>